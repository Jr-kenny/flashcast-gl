# ---------------------------------------------------------------------------
# GenLayer (Intelligent Contracts: CreditLedger + PredictionMarket)
# ---------------------------------------------------------------------------
GENLAYER_CHAIN=studionet
GENLAYER_DEPLOYER_PRIVATE_KEY=
# GENLAYER_ENDPOINT=                       # optional RPC override
CREDIT_LEDGER_CONTRACT_ADDRESS=
PREDICTION_MARKET_CONTRACT_ADDRESS=
# PREDICTION_MARKET_FEE_SINK=              # default: deployer address
# CREDIT_LEDGER_BRIDGE=                    # default: deployer address (relayer wallet)

# ---------------------------------------------------------------------------
# Base Sepolia (EVM custody: CreditVault)
# ---------------------------------------------------------------------------
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_PRIVATE_KEY=
BASESCAN_API_KEY=
CREDIT_VAULT_CONTRACT_ADDRESS=
# CREDIT_VAULT_OWNER=                      # default: first signer
CREDIT_VAULT_BRIDGE=                       # relayer authority address (must match the bridge wallet)

# ---------------------------------------------------------------------------
# Credit bridge / relayer
# ---------------------------------------------------------------------------
CREDIT_BRIDGE_ENABLED=0                    # set to 1 to run the relayer for real
CREDIT_BRIDGE_PRIVATE_KEY=                 # Base Sepolia wallet that calls vault.redeem
# symbol:address:decimals:creditsPerToken  (1 ETH -> 1000 credits here)
CREDIT_TOKENS=ETH:0x0000000000000000000000000000000000000000:18:1000
CREDIT_BRIDGE_POLL_INTERVAL_MS=15000
# CREDIT_BRIDGE_FROM_BLOCK=                # block to start scanning vault deposits

# ---------------------------------------------------------------------------
# Frontend (Vite, exposed to the browser)
# ---------------------------------------------------------------------------
VITE_GENLAYER_CHAIN=studionet
# VITE_GENLAYER_ENDPOINT=
VITE_CREDIT_LEDGER_ADDRESS=
VITE_PREDICTION_MARKET_ADDRESS=
VITE_CREDIT_VAULT_ADDRESS=
VITE_BASE_SEPOLIA_CHAIN_ID=84532
